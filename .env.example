# Genesys Cloud OAuth2 client credentials
GENESYS_CLIENT_ID=your_client_id_here
GENESYS_CLIENT_SECRET=your_client_secret_here
GENESYS_REGION=mypurecloud.com

# ChromaDB storage paths (inside Docker container)
CHROMA_DB_PATH=/data/chroma_db
CHROMA_CACHE_DIR=/data/.cache/chroma

# Optional: Discord webhook for change notifications
DISCORD_WEBHOOK_URL=
